function doGet(e) {
  var action = (e && e.parameter && e.parameter.action) || "";
  if (action === "sync") {
    return getSyncData();
  }
  return HtmlService.createHtmlOutputFromFile("index")
    .setTitle("Workout Log")
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL)
    .addMetaTag("viewport", "width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no");
}

function getAppCode() {
  return Utilities.newBlob(Utilities.base64Decode(APP_B64)).getDataAsString();
}

var APP_B64 = "";

function getSyncData() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sessions = ss.getSheetByName("Sessions");
  var setsSheet = ss.getSheetByName("Sets");
  if (!sessions || !setsSheet) {
    return ContentService.createTextOutput(JSON.stringify({status:"ok",sessions:[]})).setMimeType(ContentService.MimeType.JSON);
  }
  var sessionData = sessions.getDataRange().getValues();
  var setsData = setsSheet.getDataRange().getValues();
  if (sessionData.length <= 1) {
    return ContentService.createTextOutput(JSON.stringify({status:"ok",sessions:[]})).setMimeType(ContentService.MimeType.JSON);
  }
  var result = [];
  for (var i = 1; i < sessionData.length; i++) {
    var row = sessionData[i];
    var date = String(row[0] || "");
    var day = String(row[1] || "");
    var label = String(row[2] || "");
    var sessionSets = {};
    for (var j = 1; j < setsData.length; j++) {
      var sRow = setsData[j];
      if (String(sRow[0]) === date && String(sRow[1]) === day) {
        var exName = String(sRow[3] || "");
        if (!exName) continue;
        if (!sessionSets[exName]) sessionSets[exName] = [];
        sessionSets[exName].push({weight:String(sRow[5]||"0"),reps:String(sRow[6]||"0"),diff:String(sRow[8]||"just_right")});
      }
    }
    var dateObj = new Date(date);
    var dl = "";
    try { dl = dateObj.toLocaleDateString("en-US",{month:"short",day:"numeric"}); } catch(err) { dl = date; }
    result.push({key:date+"-"+day,date:date,day:day,label:label,dateLabel:dl,sets:sessionSets,checkIn:{energy:row[3]?Number(row[3]):"",sleep:row[4]?Number(row[4]):"",bodyweight:String(row[5]||""),notes:String(row[6]||"")},customExercises:[]});
  }
  return ContentService.createTextOutput(JSON.stringify({status:"ok",sessions:result})).setMimeType(ContentService.MimeType.JSON);
}

function doPost(e) {
  var data = JSON.parse(e.postData.contents);
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sessions = ss.getSheetByName("Sessions");
  if (!sessions) {
    sessions = ss.insertSheet("Sessions");
    sessions.appendRow(["Date","Day","Label","Energy","Sleep","Bodyweight","Notes","Volume","Sets","Exercises"]);
    sessions.getRange(1,1,1,10).setFontWeight("bold");
    sessions.setFrozenRows(1);
  }
  var setsSheet = ss.getSheetByName("Sets");
  if (!setsSheet) {
    setsSheet = ss.insertSheet("Sets");
    setsSheet.appendRow(["Date","Day","Label","Exercise","Set","Weight","Reps","Volume","Difficulty","Custom"]);
    setsSheet.getRange(1,1,1,10).setFontWeight("bold");
    setsSheet.setFrozenRows(1);
  }
  var existingData = sessions.getDataRange().getValues();
  for (var x = 1; x < existingData.length; x++) {
    if (String(existingData[x][0]) === String(data.date) && String(existingData[x][1]) === String(data.day)) {
      return ContentService.createTextOutput(JSON.stringify({status:"ok",msg:"duplicate"})).setMimeType(ContentService.MimeType.JSON);
    }
  }
  var allSets = [];
  var keys = Object.keys(data.sets || {});
  for (var i = 0; i < keys.length; i++) {
    var arr = data.sets[keys[i]];
    for (var j = 0; j < arr.length; j++) allSets.push(arr[j]);
  }
  var totalVol = 0;
  for (var i = 0; i < allSets.length; i++) {
    var w = parseFloat(allSets[i].weight) || 0;
    var r = parseInt(allSets[i].reps) || 0;
    totalVol = totalVol + (w * r);
  }
  var ci = data.checkIn || {};
  sessions.appendRow([data.date||"",data.day||"",data.label||"",ci.energy||"",ci.sleep||"",ci.bodyweight||"",ci.notes||"",totalVol,allSets.length,keys.length]);
  var customNames = [];
  var cex = data.customExercises || [];
  for (var i = 0; i < cex.length; i++) customNames.push(cex[i].name);
  for (var i = 0; i < keys.length; i++) {
    var exName = keys[i];
    var exSets = data.sets[exName];
    for (var j = 0; j < exSets.length; j++) {
      var w = parseFloat(exSets[j].weight) || 0;
      var r = parseInt(exSets[j].reps) || 0;
      setsSheet.appendRow([data.date||"",data.day||"",data.label||"",exName,j+1,w,r,w*r,exSets[j].diff||"",customNames.indexOf(exName)>=0?"Yes":""]);
    }
  }
  return ContentService.createTextOutput(JSON.stringify({status:"ok"})).setMimeType(ContentService.MimeType.JSON);
}
